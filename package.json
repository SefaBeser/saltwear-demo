{
  "name": "saltwear-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:stable": "sh -c 'PID=$(lsof -ti tcp:3000); [ -n \"$PID\" ] && kill -9 $PID || true; rm -rf .next; WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --port 3000'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001781",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
